<Window x:Class="ForceHubNativeMonitorV2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ForceHub Native Monitor V2"
        Width="1680"
        Height="950"
        MinWidth="1400"
        MinHeight="860"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Bg}">

    <Grid Background="{StaticResource Bg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource Border}"
                BorderThickness="0,0,1,0">
            <DockPanel Margin="20">

                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="ForceHub"
                               FontSize="29"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>

                    <TextBlock Text="Native Monitor V2"
                               FontSize="13"
                               Foreground="{StaticResource TextSoft}"
                               Margin="0,3,0,26"/>

                    <Button Content="Start Server" Click="StartServer_Click" Background="{StaticResource Accent}" BorderBrush="{StaticResource Accent}"/>
                    <Button Content="Start Tunnel" Click="StartTunnel_Click" Background="{StaticResource Accent}" BorderBrush="{StaticResource Accent}"/>
                    <Button Content="Start Go Live 3s" Click="StartGoLive_Click" Background="{StaticResource Green}" BorderBrush="{StaticResource Green}"/>

                    <Separator/>

                    <Button Content="Refresh Now" Click="Refresh_Click"/>
                    <Button Content="Start Auto Refresh" Click="StartAuto_Click"/>
                    <Button Content="Stop Auto Refresh" Click="StopAuto_Click"/>

                    <Separator/>

                    <Button Content="Stop Go Live" Click="StopGoLive_Click" Background="{StaticResource Orange}" BorderBrush="{StaticResource Orange}"/>
                    <Button Content="Stop Tunnel" Click="StopTunnel_Click" Background="{StaticResource Orange}" BorderBrush="{StaticResource Orange}"/>
                    <Button Content="Stop Server" Click="StopServer_Click" Background="{StaticResource Orange}" BorderBrush="{StaticResource Orange}"/>
                    <Button Content="Kill All" Click="KillAll_Click" Background="{StaticResource Red}" BorderBrush="{StaticResource Red}"/>

                    <Separator/>

                    <Button Content="Open Web Dashboard" Click="OpenDashboard_Click"/>
                    <Button Content="Open Agent Folder" Click="OpenFolder_Click"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <TextBlock Text="Status"
                               Foreground="{StaticResource TextDim}"
                               FontSize="12"
                               FontWeight="SemiBold"/>

                    <TextBlock x:Name="StatusText"
                               Text="Ready."
                               Foreground="{StaticResource TextSoft}"
                               FontSize="12"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- CENTER -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="128"/>
                <RowDefinition Height="128"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="294"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardBorder}"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="390"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ForceHub Agents"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"/>

                        <TextBlock x:Name="HeaderSubtitle"
                                   Text="API: http://127.0.0.1:18001/api/agents"
                                   Foreground="{StaticResource TextSoft}"
                                   FontSize="12"
                                   Margin="0,7,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="110"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchBox"
                                 Grid.Column="0"
                                 Height="38"
                                 Margin="0,0,12,0"
                                 TextChanged="SearchBox_TextChanged"/>

                        <Button Grid.Column="1"
                                Content="Refresh"
                                Height="38"
                                Margin="0"
                                Click="Refresh_Click"
                                Background="{StaticResource Accent}"
                                BorderBrush="{StaticResource Accent}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- METRIC STRIP -->
            <Border Grid.Row="1"
                    Style="{StaticResource CardBorder}"
                    Padding="14"
                    Margin="0,14,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="150"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Agents" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="AgentsMetric"
                                   Text="--"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Live" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="LiveMetric"
                                   Text="--"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Green}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- CPU LIVE GRAPH -->
                    <Grid Grid.Column="2" Margin="8,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="68"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock Text="CPU Live" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="CpuMetric"
                                       Text="--"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>

                        <Border Grid.Row="1"
                                CornerRadius="10"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                Background="#07101F"
                                Padding="8">
                            <Canvas x:Name="CpuGraphCanvas"
                                    ClipToBounds="True"
                                    Background="Transparent">
                                <Polyline x:Name="CpuGraph"
                                          Stroke="#3B82F6"
                                          StrokeThickness="2.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Border>
                    </Grid>

                    <!-- MEMORY LIVE GRAPH -->
                    <Grid Grid.Column="3" Margin="8,0,12,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="68"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0">
                            <TextBlock Text="Memory Live" Style="{StaticResource SectionTitle}" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="MemoryMetric"
                                       Text="--"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMain}"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>

                        <Border Grid.Row="1"
                                CornerRadius="10"
                                BorderBrush="{StaticResource Border}"
                                BorderThickness="1"
                                Background="#07101F"
                                Padding="8">
                            <Canvas x:Name="MemoryGraphCanvas"
                                    ClipToBounds="True"
                                    Background="Transparent">
                                <Polyline x:Name="MemoryGraph"
                                          Stroke="#22C55E"
                                          StrokeThickness="2.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                        <TextBlock Text="Tunnel / API" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="ApiMetric"
                                   Text="--"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- AGENTS TABLE -->
            <Border Grid.Row="2"
                    Style="{StaticResource CardBorder}"
                    Padding="16"
                    Margin="0,14,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0">
                        <TextBlock Text="Agents"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMain}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <DataGrid x:Name="AgentsGrid"
                              Grid.Row="1"
                              Margin="0,8,0,0"
                              ItemsSource="{Binding Agents}"
                              SelectionChanged="AgentsGrid_SelectionChanged"
                              AlternationCount="2"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="160"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="110"/>
                            <DataGridTextColumn Header="OS" Binding="{Binding OS}" Width="260"/>
                            <DataGridTextColumn Header="CPU %" Binding="{Binding CpuPercent}" Width="80"/>
                            <DataGridTextColumn Header="Memory" Binding="{Binding MemorySummary}" Width="170"/>
                            <DataGridTextColumn Header="Processes" Binding="{Binding ProcessCount}" Width="90"/>
                            <DataGridTextColumn Header="Uptime" Binding="{Binding Uptime}" Width="100"/>
                            <DataGridTextColumn Header="Network" Binding="{Binding NetworkSummary}" Width="300"/>
                            <DataGridTextColumn Header="Last Check-In" Binding="{Binding LastCheckIn}" Width="160"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- BOTTOM DETAILS -->
            <Border Grid.Row="3"
                    Style="{StaticResource CardBorder}"
                    Padding="16"
                    Margin="0,14,0,0">
                <TabControl>
                    <TabItem Header="Top Tasks">
                        <DataGrid x:Name="TasksGrid"
                                  ItemsSource="{Binding SelectedTasks}"
                                  Margin="0,10,0,0"
                                  AlternationCount="2"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="100"/>
                                <DataGridTextColumn Header="Process" Binding="{Binding Name}" Width="320"/>
                                <DataGridTextColumn Header="CPU %" Binding="{Binding CpuPercent}" Width="100"/>
                                <DataGridTextColumn Header="Memory MB" Binding="{Binding MemoryMb}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Network">
                        <DataGrid x:Name="NetworkGrid"
                                  ItemsSource="{Binding SelectedAdapters}"
                                  Margin="0,10,0,0"
                                  AlternationCount="2"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Adapter" Binding="{Binding Name}" Width="220"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                                <DataGridTextColumn Header="MTU" Binding="{Binding Mtu}" Width="90"/>
                                <DataGridTextColumn Header="IP Addresses" Binding="{Binding Addresses}" Width="420"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Disks">
                        <DataGrid x:Name="DisksGrid"
                                  ItemsSource="{Binding SelectedDisks}"
                                  Margin="0,10,0,0"
                                  AlternationCount="2"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Mount" Binding="{Binding Mount}" Width="160"/>
                                <DataGridTextColumn Header="Free GB" Binding="{Binding FreeGb}" Width="120"/>
                                <DataGridTextColumn Header="Total GB" Binding="{Binding TotalGb}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Raw JSON">
                        <TextBox x:Name="RawJsonBox"
                                 Margin="0,10,0,0"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="True"
                                 AcceptsTab="True"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="2"
                Margin="0,20,20,20"
                Style="{StaticResource CardBorder}"
                Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Selected Agent"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextMain}"/>

                    <TextBlock x:Name="SelectedSubtitle"
                               Text="No agent selected"
                               Foreground="{StaticResource TextSoft}"
                               FontSize="12"
                               Margin="0,6,0,22"/>

                    <Border Style="{StaticResource CardBorder}" Background="{StaticResource PanelAlt}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Identity" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="IdentityText" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Background="{StaticResource PanelAlt}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="System" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="SystemText" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Background="{StaticResource PanelAlt}" Padding="14" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Network Focus" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="NetworkFocusText" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorder}" Background="{StaticResource PanelAlt}" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Disks" Style="{StaticResource SectionTitle}"/>
                            <TextBlock x:Name="DiskText" Margin="0,10,0,0" TextWrapping="Wrap" LineHeight="20"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>



